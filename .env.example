# ─── Database ──────────────────────────────────────────────────────────────────
# Connection string for PostgreSQL. In Docker Compose this uses the service name.
DATABASE_URL="postgresql://plx:your_db_password_here@db:5432/pineapplelootxpress"

# ─── NextAuth / Auth.js ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_secret_here"

# Public URL of the app — required for OAuth redirects and session cookies
# Use http://localhost:3000 for local dev, https://yourdomain.com for prod
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# ─── Admin Access ──────────────────────────────────────────────────────────────
# Single password for the admin panel — change this to something strong!
ADMIN_PASSWORD="changeme_make_this_strong"

# ─── Docker Compose only ───────────────────────────────────────────────────────
# Used by docker-compose.yml to set the PostgreSQL container password.
# Must match the password in DATABASE_URL above.
DB_PASSWORD="your_db_password_here"

# ─── Guild Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GUILD_NAME="Your Guild Name"
NEXT_PUBLIC_GUILD_REALM="Your Realm"

# ─── Raid Schedule ─────────────────────────────────────────────────────────────
# Used for auto-creating raid weeks from Raid-Helper events.
# Day of week: 0=Sunday … 6=Saturday
RAID_NIGHT_1_DAY="2"
RAID_NIGHT_2_DAY="4"
RAID_START_TIME="20:00"
RAID_TIMEZONE="America/New_York"
# Leave blank — admins select the instance when creating a raid week.
RAID_INSTANCE=""

# ─── Branding (optional) ───────────────────────────────────────────────────────
# Override the app name, emoji, and description shown in the UI and page titles.
# Defaults to "Pineapple Loot Xpress" / 🍍 if not set.
NEXT_PUBLIC_APP_NAME="My Guild Loot"
NEXT_PUBLIC_APP_EMOJI="⚔️"
NEXT_PUBLIC_APP_DESCRIPTION="Guild loot management — Soft reserves, loot priority, and win tracking."
